;; Needed by common
(defalias
  shortcutsctl (multi lctl (layer-while-held azerty))
  shortcutsalt (multi lalt (layer-while-held azerty))
  shortcutsmet (multi lmet (layer-while-held azerty))
  zoin C-+
  zoot C--
)

(include _common.kbd)
(include _no-wide-mod.kbd)

(defsrc
  `
  q     w     e     r     t               y     u     i     o     p
  a     s     d     f     g               h     j     k     l     ;
  z     x     c     v     b               n     m     ,     .     / 
  lctl  lmet              lalt   spc   ralt  rctl
)

(deflayer base
  esc
  q     @ww   @ee   r     t               y     u     i     o     p
  @aa   @ss   @dd   @ff   g               h   @jj   @kk   @ll @rmet
  z     x     c     v     b               n     m     ,     .     /
  @lctl @met              @lalt @lctl @ralt @rctl
)

(deflayer nav
  _
  esc   XX    XX    @zoin XX           pgup  home    up   end   esc
  tab   @nss  @ndd  @nff  XX           pgdn   lft  down  rght   tab
  XX    XX    XX    XX    lrld           XX    XX    XX    XX    XX
  _     _                 _       _       _     _
)

(deflayer azerty
  _
  a     z     _     _     _               _     _     _     _     _
  q     _     _     _     _               _     _     _     _     m
  w     _     _     _     _               _     ;     _     _     _
  _     _                 _       _       _     _
)